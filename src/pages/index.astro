---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Irene Web"
  description="Architecture portfolio, selected works, and resume."
>
  <section class="hero">
    <h1>Irene’s selected works and ongoing archive.</h1>
    <p>
      Architecture portfolio, research fragments, and professional materials.
      This website is built as a long-term personal archive rather than a temporary job-hunting page.
    </p>
  </section>

  <section class="section">
    <p class="section-title">Selected Projects</p>
    <div class="project-list">
      <article class="project-card">
        <div class="project-year">2025</div>
        <div>
          <h3>Project One</h3>
          <p>
            Replace this with a studio, competition, internship, or research project
            that best represents your architectural thinking and visual language.
          </p>
        </div>
      </article>

      <article class="project-card">
        <div class="project-year">2024</div>
        <div>
          <h3>Project Two</h3>
          <p>
            Use this section to present another project with a different scale,
            method, or narrative emphasis.
          </p>
        </div>
      </article>

      <article class="project-card">
        <div class="project-year">2023</div>
        <div>
          <h3>Project Three</h3>
          <p>
            You can later replace these placeholders with real project pages,
            cover images, and detailed process documentation.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <p class="section-title">Current Use</p>
    <div class="simple-list">
      <div class="simple-card">Portfolio for applications and interviews.</div>
      <div class="simple-card">Archive for research, writing, and process-based work.</div>
      <div class="simple-card">Long-term personal platform with room to expand.</div>
    </div>
  </section>
</BaseLayout>
