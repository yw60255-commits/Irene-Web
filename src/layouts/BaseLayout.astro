---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Irene Wang — Ongoing Practice",
  description = "Design, AI, smart environments, and ongoing curiosities. 这里不仅有作品、项目与研究，也有我持续展开的实践与观察。"
} = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Resume", href: "/resume" },
  { label: "Design", href: "/design" },
  { label: "Projects", href: "/projects" },
  { label: "AI", href: "/ai" },
  { label: "Research", href: "/research" }
];

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/" || currentPath === "";
  }
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fcfcfa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="site-logo" href="/">
          <span class="site-logo-main">Irene</span>
          <span class="site-logo-sub">WANG Yifan</span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} class={isActive(item.href) ? "active" : ""}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="page-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <p class="footer-name">WANG Yifan - Irene</p>
          <p class="footer-text">Design, AI, smart environments, and ongoing curiosities.</p>
        </div>
        <p class="footer-copy">© 2026 Irene. Personal website in progress.</p>
      </div>
    </footer>
  </body>
</html>